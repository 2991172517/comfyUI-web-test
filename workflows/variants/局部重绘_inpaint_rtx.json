{
  "1": {
    "inputs": {
      "ckpt_name": "waiIllustriousSDXL_v170.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "加载 Checkpoint"
    }
  },
  "2": {
    "inputs": {
      "clip": ["1", 1],
      "stop_at_clip_layer": -2
    },
    "class_type": "CLIPSetLastLayer",
    "_meta": {
      "title": "CLIP Skip -2"
    }
  },
  "3": {
    "inputs": {
      "text": "masterpiece, best quality, detailed",
      "clip": ["2", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "正向提示词"
    }
  },
  "4": {
    "inputs": {
      "text": "lowres, bad anatomy, bad hands, text, error, missing fingers, extra digit, fewer digits, cropped, worst quality, low quality, normal quality, jpeg artifacts, signature, watermark, username, blurry",
      "clip": ["2", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "负向提示词"
    }
  },
  "10": {
    "inputs": {
      "image": "inpaint_source.png"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "原图（上传）"
    }
  },
  "11": {
    "inputs": {
      "image": "inpaint_mask.png",
      "channel": "red"
    },
    "class_type": "LoadImageMask",
    "_meta": {
      "title": "蒙版（白=重绘，上传）"
    }
  },
  "20": {
    "inputs": {
      "positive": ["3", 0],
      "negative": ["4", 0],
      "vae": ["1", 2],
      "pixels": ["10", 0],
      "mask": ["11", 0],
      "noise_mask": true
    },
    "class_type": "InpaintModelConditioning",
    "_meta": {
      "title": "Inpaint 条件 + Latent"
    }
  },
  "30": {
    "inputs": {
      "seed": 0,
      "steps": 28,
      "cfg": 6,
      "sampler_name": "euler_ancestral",
      "scheduler": "karras",
      "denoise": 0.55,
      "model": ["1", 0],
      "positive": ["20", 0],
      "negative": ["20", 1],
      "latent_image": ["20", 2]
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "局部重绘采样"
    }
  },
  "40": {
    "inputs": {
      "samples": ["30", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE 解码"
    }
  },
  "60": {
    "inputs": {
      "resize_type": "scale by multiplier",
      "resize_type.scale": 1.5,
      "quality": "ULTRA",
      "images": ["40", 0]
    },
    "class_type": "RTXVideoSuperResolution",
    "_meta": {
      "title": "RTX 放大 1.5x（可选流）"
    }
  },
  "50": {
    "inputs": {
      "filename_prefix": "inpaint_rtx",
      "images": ["60", 0]
    },
    "class_type": "SaveImage",
    "_meta": {
      "title": "保存结果"
    }
  }
}
