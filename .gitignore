# ========== 前端（勿提交依赖与构建产物）==========
node_modules/
**/node_modules/
frontEnd/dist/
frontEnd/dist-ssr/
frontend/dist/
frontEnd/UI参考/**
*.local

# ========== 闭源打包产物（PyInstaller / release，体积大，勿提交）==========
bin/
release/
*.zip

# PyInstaller 中间目录与输出（backEnd 内）
backEnd/build/
backEnd/dist/

# exe 运行时在项目根生成的可重建数据
/data/

# 兼容旧规则（其它目录若出现 build/dist 也忽略）
build/
dist/

# ========== Python 后端（勿提交虚拟环境与缓存）==========
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/
.env
.env.*
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/

# backEnd / backend 目录均适用（项目实际代码在 backEnd）
backEnd/.venv/
backend/.venv/

# ========== 日志与本地输出 ==========
logs/
*.log

# ========== 脚本本地大文件 / 备份 ==========
scripts/category_标签库_*/
**/manifest.json.bak

# ========== 密钥 ==========
config/civitai_token.txt
**/civitai_token.txt

# ========== 编辑器与系统 ==========
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
